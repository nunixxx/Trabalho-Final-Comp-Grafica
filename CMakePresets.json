{
  "version": 6,
  "configurePresets": [
    {
      "name": "default-config",
      "binaryDir": "${sourceDir}/build",
      "generator": "MinGW Makefiles",
      "cacheVariables": {
        "CMAKE_C_COMPILER": "gcc",
        "CMAKE_CXX_COMPILER": "g++"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "default-build",
      "configurePreset": "default-config"
    },
    {
      "name": "build-run",
      "configurePreset": "default-config",
      "targets": ["run"]
    }
  ],
  "workflowPresets": [
    {
      "name": "configure-build-run",
      "steps": [
        {
          "type": "configure",
          "name": "default-config"
        },
        {
          "type": "build",
          "name": "build-run"
        }
      ]
    }
  ]
}